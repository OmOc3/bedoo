{
  "name": "ecopest-bait-station-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NEXT_PRIVATE_BUILD_WORKER=1 next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types --import ./tests/register-ts-loader.mjs \"tests/**/*.test.ts\"",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node scripts/seed-manager.mjs",
    "auth:clear-rate-limit": "node scripts/clear-login-rate-limit.mjs",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:web": "npm --prefix mobile run web",
    "mobile:lint": "npm --prefix mobile run lint",
    "mobile:typecheck": "npm --prefix mobile exec -- tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.9",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.3",
    "@opentelemetry/api": "^1.9.1",
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "kysely": "^0.28.16",
    "next": "^15.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.66.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.8.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3"
  }
}
