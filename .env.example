# Local SQLite database. Use hosted libSQL/Turso with DATABASE_AUTH_TOKEN in production/Vercel.
DATABASE_URL=file:./data/ecopest.db
DATABASE_AUTH_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
AUTH_ROLE_COOKIE_SECRET=
SESSION_MAX_AGE_SECONDS=432000

# Required in production. Must be a valid https URL in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# First local manager seed. Used only by npm run db:seed.
SEED_MANAGER_EMAIL=manager@example.com
SEED_MANAGER_PASSWORD=change-this-password
SEED_MANAGER_NAME=مدير النظام

GEMINI_API_KEY=
# Optional. Defaults to gemini-2.5-flash.
GEMINI_MODEL=

# Cloudinary station photos
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_STATION_FOLDER=ecopest/stations
CLOUDINARY_REPORT_FOLDER=ecopest/reports
# When Cloudinary is not configured, report photos are stored as data URLs in SQLite (see store-report-image).

# Optional. If set, used to sign station QR links instead of deriving from BETTER_AUTH_SECRET only.
ECOPEST_QR_SECRET=

EXPO_PUBLIC_ECOPEST_WEB_BASE_URL=https://ecopest-production.vercel.app/

# Technician support links
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_SUPPORT_PHONE=

# Maintenance mode (blocks client + technician without logging them out)
# Set to 1/true/on to enable.
MAINTENANCE_MODE=0
# Optional. Middleware status cache TTL in seconds. Defaults to 60 in dev and 0 in production.
MAINTENANCE_STATUS_CACHE_SECONDS=
