# Local SQLite database. Use libsql://... with DATABASE_AUTH_TOKEN in production.
DATABASE_URL=file:./data/mawqi3.db
DATABASE_AUTH_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3002
AUTH_ROLE_COOKIE_SECRET=
SESSION_MAX_AGE_SECONDS=432000

# Required in production. Must be a valid https URL in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3002

# First local manager seed.
SEED_MANAGER_EMAIL=manager@example.com
SEED_MANAGER_PASSWORD=change-this-password
SEED_MANAGER_NAME=مدير النظام

GEMINI_API_KEY=

EXPO_PUBLIC_MAWQI3_WEB_BASE_URL=http://localhost:3002
